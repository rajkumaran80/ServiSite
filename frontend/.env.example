# API
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# App domain for subdomain-based multi-tenancy
# Local dev: "localhost" → opens http://{slug}.localhost:3000
# Production: "servisite.co.uk" → opens https://{slug}.servisite.co.uk
NEXT_PUBLIC_APP_DOMAIN=localhost

# For local development with subdomains:
# Add entries to /etc/hosts:
# 127.0.0.1  pizza-palace.localhost
# Then access: http://pizza-palace.localhost:3000

# Shared secret for cache revalidation (must match backend REVALIDATE_SECRET)
# Generate: openssl rand -hex 32
REVALIDATE_SECRET=change-me-generate-a-random-hex-string

# Shared secret sent to backend on every request (must match backend INTERNAL_SECRET)
# Leave blank locally — backend skips the check in development
INTERNAL_SECRET=
