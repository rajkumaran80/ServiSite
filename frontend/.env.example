# ── API ───────────────────────────────────────────────────────────────────────
# Local dev:  http://localhost:3001/api/v1
# Production: https://www.servisite.co.uk/api/v1  (routed through Front Door)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# ── App Domain (multi-tenancy) ────────────────────────────────────────────────
# Local dev:  "localhost"       → superadmin opens http://{slug}.localhost:3000
# Production: "servisite.co.uk" → superadmin opens https://{slug}.servisite.co.uk
NEXT_PUBLIC_APP_DOMAIN=localhost

# For local subdomain dev, add entries to /etc/hosts:
#   127.0.0.1  mirisa.localhost
#   127.0.0.1  pizza-palace.localhost
# Most modern browsers (Chrome, Edge) resolve *.localhost natively without /etc/hosts.

# ── Shared secrets (must match backend) ───────────────────────────────────────
# Generate: openssl rand -hex 32
REVALIDATE_SECRET=change-me-generate-a-random-hex-string
# Sent to backend on every request. Leave blank locally — backend skips check in dev.
NEXT_PUBLIC_INTERNAL_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Must match GOOGLE_CLIENT_ID in backend .env
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── Stripe (publishable key only — secret key stays in backend) ───────────────
# Get from: https://dashboard.stripe.com/developers/api-keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
