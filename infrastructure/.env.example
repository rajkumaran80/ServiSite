# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=servisite
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=servisite

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_generate_a_long_random_secret_here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── Azure Blob Storage ───────────────────────────────────────────────────────
# From Azure Portal → Storage Account → Access keys → Connection string
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=servisite-media

# ─── Application ─────────────────────────────────────────────────────────────
APP_DOMAIN=servisite.com
NEXT_PUBLIC_API_URL=https://api.servisite.com
