{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "dbPassword": { "value": "REPLACE — strong password, min 16 chars" },
    "jwtSecret": { "value": "REPLACE — openssl rand -hex 32" },
    "revalidateSecret": { "value": "REPLACE — openssl rand -hex 32" },
    "internalSecret": { "value": "REPLACE — openssl rand -hex 32" },

    "stripeSecretKey": { "value": "sk_live_..." },
    "stripeWebhookSecret": { "value": "whsec_..." },

    "smtpPassword": { "value": "REPLACE — SendGrid API key or SMTP password" },

    "vapidPublicKey": { "value": "REPLACE — run: npx web-push generate-vapid-keys" },
    "vapidPrivateKey": { "value": "REPLACE — run: npx web-push generate-vapid-keys" },

    "twilioAccountSid": { "value": "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" },
    "twilioAuthToken": { "value": "" },

    "googleClientId": { "value": "REPLACE — from Google Cloud Console" },
    "googlePlacesApiKey": { "value": "REPLACE — from Google Cloud Console > APIs & Services > Places API" },

    "nextPublicStripePublishableKey": { "value": "pk_live_..." },
    "nextPublicGoogleClientId": { "value": "REPLACE — same as googleClientId" }
  }
}
