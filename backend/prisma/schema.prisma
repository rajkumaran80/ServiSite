// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantType {
  RESTAURANT
  CAFE
  BARBER_SHOP
  SALON
  GYM
  REPAIR_SHOP
  OTHER
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  STAFF
}

model Tenant {
  id             String     @id @default(cuid())
  name           String
  slug           String     @unique
  type           TenantType @default(RESTAURANT)
  logo           String?
  banner         String?
  themeSettings  Json?      @default("{}")
  currency       String     @default("USD")
  timezone       String     @default("UTC")
  locale         String     @default("en")
  whatsappNumber String?
  qrCodeUrl      String?
  // Custom domain support
  customDomain          String?   @unique
  customDomainStatus    String?   // pending | active | failed
  customDomainToken     String?   // DNS TXT verification token (legacy)
  customDomainVerifiedAt DateTime?
  customDomainNsRecords String[]  // Azure DNS Zone nameservers to add in registrar
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  users           User[]
  categories      Category[]
  menuItems       MenuItem[]
  menuGroups      MenuGroup[]
  contactInfo     ContactInfo?
  gallery         GalleryImage[]
  navigationItems NavigationItem[]
  pages           Page[]
  pageEntries     PageEntry[]

  @@map("tenants")
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  role         UserRole @default(STAFF)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@unique([tenantId, email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model MenuGroup {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  icon        String?
  description String?
  servedFrom  String?
  servedUntil String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categories Category[]

  @@map("menu_groups")
}

model Category {
  id            String   @id @default(cuid())
  tenantId      String
  menuGroupId String?
  name        String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  menuGroup MenuGroup? @relation(fields: [menuGroupId], references: [id], onDelete: SetNull)
  menuItems MenuItem[]

  @@map("categories")
}

model MenuItem {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("USD")
  imageUrl    String?
  isAvailable Boolean  @default(true)
  isPopular   Boolean  @default(false)
  allergens   String[]
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categories Category[]

  @@map("menu_items")
}

model ContactInfo {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  phone        String?
  email        String?
  address      String?
  city         String?
  state        String?
  country      String?
  zipCode      String?
  mapUrl       String?
  openingHours Json?    @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("contact_info")
}

model GalleryImage {
  id        String   @id @default(cuid())
  tenantId  String
  url       String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("gallery_images")
}

model NavigationItem {
  id           String   @id @default(cuid())
  tenantId     String
  label        String
  href         String
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  openInNewTab Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("navigation_items")
}

model Page {
  id          String   @id @default(cuid())
  tenantId    String
  slug        String
  title       String
  sections    Json     @default("[]")
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@map("pages")
}

model PageEntry {
  id        String   @id @default(cuid())
  tenantId  String
  pageKey   String
  title     String
  imageUrl  String?
  data      Json     @default("{}")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, pageKey])
  @@map("page_entries")
}
