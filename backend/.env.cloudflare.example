# Cloudflare for SaaS Configuration
# Copy these variables to your .env file for Azure deployment

# Cloudflare API Configuration
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ZONE_ID=your_servisite_zone_id_here
CLOUDFLARE_ZONE_NAME=servisite.co.uk

# Cloudflare Polling Configuration
CLOUDFLARE_POLLING_ENABLED=true
CLOUDFLARE_POLL_INTERVAL=30000

# Azure App Service Configuration
AZURE_APP_SERVICE_URL=https://your-app-service.azurewebsites.net

# Cloudflare IP Ranges for Azure Security Rules
# Update these with the latest Cloudflare IP ranges
# See: https://www.cloudflare.com/ips/
CLOUDFLARE_IPV4_RANGES=173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,103.31.4.0/22,104.16.0.0/13,104.24.0.0/14,108.162.192.0/18,131.0.72.0/22,141.101.64.0/18,162.158.0.0/15,172.64.0.0/13,190.93.240.0/20,188.114.96.0/20,197.234.240.0/22,198.41.128.0/17
CLOUDFLARE_IPV6_RANGES=2400:cb00::/32,2606:4700::/32,2803:f800::/32,2405:b500::/32,2405:8100::/32,2c0f:f248::/32,2a06:98c0::/29

# Instructions for Azure Configuration:
# 1. Set up IP Security Restrictions in Azure App Service
# 2. Add Cloudflare IP ranges to allow list
# 3. Enable Authenticated Origin Pulls in Cloudflare
# 4. Configure origin.servisite.co.uk to point to Azure App Service
