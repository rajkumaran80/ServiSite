# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://servisite:servisite_password@localhost:5432/servisite_db?schema=public"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── App Domain (multi-tenancy) ────────────────────────────────────────────────
# Local dev:  localhost         → tenant accessed at http://{slug}.localhost:3000
# Production: servisite.co.uk   → tenant accessed at https://{slug}.servisite.co.uk
APP_DOMAIN=localhost
APP_URL=http://localhost:3000

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ── Shared secrets (must match frontend) ─────────────────────────────────────
# Generate: openssl rand -hex 32
REVALIDATE_SECRET=change-me-generate-a-random-hex-string
# Skipped in NODE_ENV=development — safe to leave blank locally
INTERNAL_SECRET=

# ── Redis (optional — leave blank to disable caching) ─────────────────────────
# Local dev: docker compose -f infrastructure/docker-compose.dev.yml up -d redis
REDIS_URL=redis://localhost:6379

# ── Azure Blob Storage ────────────────────────────────────────────────────────
# Local dev — Azurite emulator (docker compose -f infrastructure/docker-compose.dev.yml up -d azurite)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;
# Production: replace with real Azure Storage connection string
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=servisite-media
AZURE_STORAGE_SAS_EXPIRY_HOURS=24
# Optional CDN endpoint — set to rewrite blob URLs to CDN for faster video delivery.
# Azure Portal → Storage Account → Front Door & CDN → Create endpoint, then paste hostname here.
# Example: https://servisitemedia.azureedge.net
AZURE_CDN_URL=

# ── Cloudflare for SaaS (tenant custom domain provisioning) ───────────────────
# API token: Cloudflare → My Profile → API Tokens → Custom Token
# Permissions: Zone SSL and Certificates Edit, Zone Read, Zone Settings Read
CLOUDFLARE_API_KEY=
CLOUDFLARE_ZONE_ID=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/developers/api-keys
STRIPE_SECRET_KEY=sk_test_...
# Get from: https://dashboard.stripe.com/webhooks  (your webhook endpoint → Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Local dev: use Mailtrap (https://mailtrap.io) or leave blank to skip email sending
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_ADDRESS=noreply@servisite.co.uk
EMAIL_FROM_NAME=ServiSite

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Must match NEXT_PUBLIC_GOOGLE_CLIENT_ID in frontend .env
GOOGLE_CLIENT_ID=

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate a new keypair: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY must also be set in frontend as NEXT_PUBLIC_VAPID_PUBLIC_KEY (if used client-side)
# The backend exposes it via GET /api/v1/billing/push/vapid-public-key — frontend fetches it at runtime
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@servisite.co.uk

# ── Twilio WhatsApp (order notifications) ────────────────────────────────────
# Get from: https://console.twilio.com
# Leave blank to disable WhatsApp notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Superadmin alerts ─────────────────────────────────────────────────────────
# Email address that receives platform-level alerts (payment failures, suspensions, etc.)
SUPERADMIN_ALERT_EMAIL=admin@servisite.co.uk

# ── Google Places API ─────────────────────────────────────────────────────────
# Used to fetch Google reviews for tenant home pages. Free up to ~11,700 req/month.
# Get a key at: https://console.cloud.google.com/apis/library/places-backend.googleapis.com
GOOGLE_PLACES_API_KEY=
